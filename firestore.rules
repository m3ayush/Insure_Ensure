rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Users collection
    match /users/{uid} {
      // Only the owner can read their own profile
      allow read: if request.auth != null && request.auth.uid == uid;

      // Owner can create their own doc at signup (all fields allowed on create)
      allow create: if request.auth != null && request.auth.uid == uid;

      // Owner can update profile fields but NOT is_active or failed_login_attempts
      // (those are server-side only — written by Firebase Admin SDK / Cloud Functions)
      allow update: if request.auth != null
        && request.auth.uid == uid
        && !request.resource.data.diff(resource.data).affectedKeys()
            .hasAny(['is_active', 'failed_login_attempts']);

      // Clients cannot delete user docs (soft-delete via is_active only, done server-side)
      allow delete: if false;

      // Sessions subcollection: owner read-only (writes come from server via Admin SDK)
      match /sessions/{sessionId} {
        allow read: if request.auth != null && request.auth.uid == uid;
        allow write: if false;
      }
    }

    // Login attempts audit log: server-write only, no client access
    match /login_attempts/{docId} {
      allow read, write: if false;
    }

    // Deny everything else by default
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
